# ─── App ───────────────────────────────────────
APP_ENV=development
APP_PORT=3000

# ─── Datenbank ─────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=vertragsverwaltung
DB_USER=vv_user
DB_PASSWORD=changeme_db

# ─── JWT ───────────────────────────────────────
JWT_SECRET=changeme_jwt_secret_min32chars!!
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=changeme_refresh_secret!!
JWT_REFRESH_EXPIRES_IN=7d

# ─── Redis ─────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ─── E-Mail (nodemailer) ───────────────────────
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=noreply@example.com
MAIL_PASS=changeme_mail

# ─── Paperless-NGX ─────────────────────────────
# Wird pro Mandant in der DB gespeichert.
# Hier nur der Default für lokale Entwicklung:
PAPERLESS_BASE_URL=http://paperless:8000
PAPERLESS_API_TOKEN=your_paperless_token_here
