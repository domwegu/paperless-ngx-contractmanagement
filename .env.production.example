# ─── App ───────────────────────────────────────
APP_ENV=production
APP_PORT=3000

# ─── Datenbank ─────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=vertragsverwaltung
DB_USER=vv_user
DB_PASSWORD=SICHERES_PASSWORT_HIER          # min. 32 Zeichen, zufällig

# ─── JWT ───────────────────────────────────────
JWT_SECRET=MINDESTENS_32_ZEICHEN_ZUFAELLIG!!
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=ANDERER_ZUFAELLIGER_STRING
JWT_REFRESH_EXPIRES_IN=7d

# ─── Redis ─────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ─── E-Mail ────────────────────────────────────
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=noreply@example.com
MAIL_PASS=MAIL_PASSWORT

# ─── Paperless (Default, wird pro Mandant überschrieben) ──
PAPERLESS_BASE_URL=http://paperless:8000
PAPERLESS_API_TOKEN=

# ─── Zeitzone ──────────────────────────────────
TZ=Europe/Berlin
